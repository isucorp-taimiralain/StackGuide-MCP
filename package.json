{
  "name": "@stackguide/mcp-server",
  "version": "4.1.1",
  "description": "MCP Server for dynamic language and framework context loading - Compatible with Cursor and GitHub Copilot",
  "main": "dist/index.js",
  "bin": {
    "stackguide-mcp": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "pnpm run build",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cursor",
    "copilot",
    "ai",
    "context",
    "rules",
    "django",
    "react",
    "node",
    "python"
  ],
  "author": "Taimir Alain Morales Roche <taimiralain>",
  "license": "GPL-3.0",
  "mcpName": "io.github.isucorp-taimiralain/stackguide-mcp",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.5.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "ts-morph": "^27.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.0.16",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "data",
    "socket.yml"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/stackguide/mcp-server"
  }
}
